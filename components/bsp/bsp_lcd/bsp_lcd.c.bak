#include "bsp_lcd.h"
#include "bsp_lcd_fonts.h"

typedef struct
{
    uint32_t pwidth; /* 临时设定值（宽度） */
    uint32_t pheight; /* 临时设定值（高度） */
    uint8_t dir; /* 屏幕方向 */
    uint16_t width; /* 宽度 */
    uint16_t height; /* 高度 */
} _lcd_dev_t;

static void _lcd_spi_init(void);
static void _lcd_exio_pin_init(void);
static bool _lcd_flush_ready_cb(esp_lcd_panel_io_handle_t panel_io, esp_lcd_panel_io_event_data_t *edata, void *arg);
static uint32_t _lcd_pow(uint8_t m, uint8_t n);

const char *TAG = "lcd.c";
const esp_lcd_panel_io_callbacks_t cbs = { .on_color_trans_done = _lcd_flush_ready_cb };
static DRAM_ATTR uint8_t g_lcd_refresh_ok_flag = 0;
static esp_lcd_panel_handle_t g_lcd_handle = NULL;
static _lcd_dev_t g_lcd_dev;

/**
 * @brief       LCD初始化
 * @param       无
 * @retval      无
 */
void bsp_lcd_init(void)
{
    _lcd_exio_pin_init();
    _lcd_spi_init();

    BSP_LCD_RST(0);
    vTaskDelay(100);
    BSP_LCD_RST(1);
    vTaskDelay(100);

    esp_lcd_panel_io_handle_t io_handle = NULL;

    esp_lcd_panel_io_spi_config_t io_config = {
        .dc_gpio_num = BSP_LCD_DC_PIN,
        .cs_gpio_num = BSP_LCD_CS_PIN,
        .pclk_hz = EK_FREQ_M(60),
        .lcd_cmd_bits = 8,
        .lcd_param_bits = 8,
        .spi_mode = 0,
        .trans_queue_depth = 10,
    };
    ESP_ERROR_CHECK(esp_lcd_new_panel_io_spi(LCD_SPI_HOST, &io_config, &io_handle));

    g_lcd_dev.pwidth = LCD_WIDTH;
    g_lcd_dev.pheight = LCD_HEIGHT;

    esp_lcd_panel_dev_config_t panel_config = {
        .reset_gpio_num = GPIO_NUM_NC,
        .rgb_ele_order = COLOR_RGB_ELEMENT_ORDER_RGB,
        .bits_per_pixel = 16,
        .data_endian = LCD_RGB_DATA_ENDIAN_BIG,
    };
    ESP_ERROR_CHECK(esp_lcd_new_panel_st7789(io_handle, &panel_config, &g_lcd_handle));
    ESP_ERROR_CHECK(esp_lcd_panel_reset(g_lcd_handle));
    ESP_ERROR_CHECK(esp_lcd_panel_invert_color(g_lcd_handle, true));
    ESP_ERROR_CHECK(esp_lcd_panel_init(g_lcd_handle));
    ESP_ERROR_CHECK(esp_lcd_panel_disp_on_off(g_lcd_handle, true));
    ESP_ERROR_CHECK(esp_lcd_panel_io_register_event_callbacks(io_handle, &cbs, NULL));

    bsp_lcd_set_dir(1);
    bsp_lcd_clear(WHITE);
    BSP_LCD_PWR(1);
}

/**
 * @brief       设置屏幕方向
 * @param       dir: 0为竖屏，1为横屏
 * @retval      无
 */
void bsp_lcd_set_dir(uint8_t dir)
{
    g_lcd_dev.dir = dir;

    if (g_lcd_dev.dir == 0) /* 竖屏 */
    {
        g_lcd_dev.width = g_lcd_dev.pheight;
        g_lcd_dev.height = g_lcd_dev.pwidth;
        esp_lcd_panel_swap_xy(g_lcd_handle, false);
        esp_lcd_panel_mirror(g_lcd_handle, false, false);

#ifndef LCD_2_4_INCH
        esp_lcd_panel_set_gap(g_lcd_handle, 0, 80);
#endif
    }
    else if (g_lcd_dev.dir == 1) /* 横屏 */
    {
        g_lcd_dev.width = g_lcd_dev.pwidth;
        g_lcd_dev.height = g_lcd_dev.pheight;
        esp_lcd_panel_swap_xy(g_lcd_handle, true);
        esp_lcd_panel_mirror(g_lcd_handle, true, false);

#ifndef LCD_2_4_INCH
        esp_lcd_panel_set_gap(g_lcd_handle, 80, 0);
#endif
    }
}

/**
 * @brief       清屏
 * @param       color: 颜色值
 * @retval      无
 */
void bsp_lcd_clear(uint16_t color)
{
    const uint16_t rows = 40;
    uint16_t *buffer = heap_caps_malloc(g_lcd_dev.width * sizeof(uint16_t) * rows, MALLOC_CAP_DMA);
    uint16_t color_tmp = ((color & 0x00FF) << 8) | ((color & 0xFF00) >> 8); /* 需要转换一下颜色值 */
    if (NULL == buffer)
    {
        ESP_LOGE(TAG, "Memory allocation failed! Requested: %d bytes", g_lcd_dev.width * sizeof(uint16_t) * rows);
    }
    else
    {
        for (uint32_t i = 0; i < g_lcd_dev.width * rows; i++)
        {
            buffer[i] = color_tmp;
        }

        for (uint16_t y = 0; y < g_lcd_dev.height; y += rows)
        {
            esp_lcd_panel_draw_bitmap(g_lcd_handle, 0, y, g_lcd_dev.width, y + rows, buffer);
        }
    }

    g_lcd_refresh_ok_flag = 0;

    do
    {
        /* 等待内部缓存刷新完成 */
        vTaskDelay(1);
    } while (g_lcd_refresh_ok_flag != 1);

    heap_caps_free(buffer);
}

/**
 * @brief       在指定区域内填充单个颜色
 * @param       sx    : 起始x坐标
 * @param       sy    : 起始y坐标
 * @param       ex    : 结束x坐标
 * @param       ey    : 结束y坐标
 * @param       color : 要填充的颜色
 * @retval      无
 */
void bsp_lcd_fill(uint16_t sx, uint16_t sy, uint16_t ex, uint16_t ey, uint16_t color)
{
    /* 计算填充区域宽度 */
    uint16_t width = ex - sx;
    uint16_t height = ey - sy;

    /* 分配内存 */
    uint16_t *buffer = heap_caps_malloc(width * sizeof(uint16_t), MALLOC_CAP_INTERNAL);
    uint16_t color_tmp = ((color & 0x00FF) << 8) | ((color & 0xFF00) >> 8); /* 需要转换一下颜色值 */

    if (NULL == buffer)
    {
        ESP_LOGE(TAG, "Memory for bitmap is not enough");
    }
    else
    {
        /* 填充颜色 */
        for (uint16_t i = 0; i < width; i++)
        {
            buffer[i] = color_tmp;
        }

        /* 绘制填充区域 */
        for (uint16_t y = 0; y < height; y++)
        {
            esp_lcd_panel_draw_bitmap(g_lcd_handle, sx, sy + y, ex, sy + y + 1, buffer);
        }

        /* 释放内存 */
        heap_caps_free(buffer);
    }
}

/**
 * @brief       绘画一个像素点
 * @param       x    : x轴坐标
 * @param       y    : y轴坐标
 * @param       color: 颜色值
 * @retval      无
 */
void bsp_lcd_draw_point(uint16_t x, uint16_t y, uint16_t color)
{
    uint16_t color_tmp = ((color & 0x00FF) << 8) | ((color & 0xFF00) >> 8); /* 需要转换一下颜色值 */
    esp_lcd_panel_draw_bitmap(g_lcd_handle, x, y, x + 1, y + 1, &color_tmp);
}

/**
 * @brief       画线函数(直线、斜线)
 * @param       x1    : 起点x坐标
 * @param       y1    : 起点y坐标
 * @param       x2    : 终点x坐标
 * @param       y2    : 终点y坐标
 * @param       color : 填充颜色
 * @retval      无
 */
void bsp_lcd_draw_line(uint16_t x1, uint16_t y1, uint16_t x2, uint16_t y2, uint16_t color)
{
    uint16_t t;
    int xerr = 0, yerr = 0, delta_x, delta_y, distance;
    int incx, incy, row, col;
    delta_x = x2 - x1;
    delta_y = y2 - y1;
    row = x1;
    col = y1;

    if (delta_x > 0)
    {
        incx = 1;
    }
    else if (delta_x == 0)
    {
        incx = 0;
    }
    else
    {
        incx = -1;
        delta_x = -delta_x;
    }

    if (delta_y > 0)
    {
        incy = 1;
    }
    else if (delta_y == 0)
    {
        incy = 0;
    }
    else
    {
        incy = -1;
        delta_y = -delta_y;
    }

    if (delta_x > delta_y)
    {
        distance = delta_x;
    }
    else
    {
        distance = delta_y;
    }

    for (t = 0; t <= distance + 1; t++)
    {
        bsp_lcd_draw_point(row, col, color);
        xerr += delta_x;
        yerr += delta_y;

        if (xerr > distance)
        {
            xerr -= distance;
            row += incx;
        }

        if (yerr > distance)
        {
            yerr -= distance;
            col += incy;
        }
    }
}

/**
 * @brief       画水平线
 * @param       x     : 起点x坐标
 * @param       y     : 起点y坐标
 * @param       len   : 线长度
 * @param       color : 矩形的颜色
 * @retval      无
 */
void bsp_lcd_draw_hline(uint16_t x, uint16_t y, uint16_t len, uint16_t color)
{
    /* 确保坐标在LCD范围内 */
    if (len == 0 || x >= g_lcd_dev.width || y >= g_lcd_dev.height) return;

    uint16_t ex = fminf(g_lcd_dev.width - 1, x + len - 1);
    uint16_t ey = y;

    /* 填充颜色区域 */
    uint32_t width = ex - x + 1;
    uint32_t h = ey - y + 1;
    uint16_t *color_buffer = malloc(width * h * sizeof(uint16_t));

    if (color_buffer == NULL)
    {
        return; /* 检查内存分配是否成功 */
    }

    for (uint32_t i = 0; i < width * h; i++)
    {
        color_buffer[i] = color;
    }

    esp_lcd_panel_draw_bitmap(g_lcd_handle, x, y, ex + 1, ey + 1, color_buffer);
    free(color_buffer);
}

/**
 * @brief       画一个矩形
 * @param       x0    : 起点x坐标
 * @param       y0    : 起点y坐标
 * @param       x1    : 终点x坐标
 * @param       y1    : 终点y坐标
 * @param       color : 填充颜色
 * @retval      无
 */
void bsp_lcd_draw_rectangle(uint16_t x0, uint16_t y0, uint16_t x1, uint16_t y1, uint16_t color)
{
    bsp_lcd_draw_line(x0, y0, x1, y0, color);
    bsp_lcd_draw_line(x0, y0, x0, y1, color);
    bsp_lcd_draw_line(x0, y1, x1, y1, color);
    bsp_lcd_draw_line(x1, y0, x1, y1, color);
}

/**
 * @brief       画一个圆
 * @param       x0    : 圆心x坐标
 * @param       y0    : 圆心y坐标
 * @param       r     : 圆半径
 * @param       color : 填充颜色
 * @retval      无
 */
void bsp_lcd_draw_circle(uint16_t x0, uint16_t y0, uint16_t r, uint16_t color)
{
    int a, b;
    int di;
    a = 0;
    b = r;
    di = 3 - (r << 1);

    while (a <= b)
    {
        bsp_lcd_draw_point(x0 - b, y0 - a, color);
        bsp_lcd_draw_point(x0 + b, y0 - a, color);
        bsp_lcd_draw_point(x0 - a, y0 + b, color);
        bsp_lcd_draw_point(x0 - b, y0 - a, color);
        bsp_lcd_draw_point(x0 - a, y0 - b, color);
        bsp_lcd_draw_point(x0 + b, y0 + a, color);
        bsp_lcd_draw_point(x0 + a, y0 - b, color);
        bsp_lcd_draw_point(x0 + a, y0 + b, color);
        bsp_lcd_draw_point(x0 - b, y0 + a, color);
        a++;

        if (di < 0)
        {
            di += 4 * a + 6;
        }
        else
        {
            di += 10 + 4 * (a - b);
            b--;
        }

        bsp_lcd_draw_point(x0 + a, y0 + b, color);
    }
}

/**
 * @brief       在指定位置显示一个字符
 * @param       x     : x坐标
 * @param       y     : y坐标
 * @param       font  : 字体大小 可选: 12, 16, 24, 32
 * @param       color : 字符颜色
 * @param       mode  : 叠加方式 0=非叠加, 1=叠加
 * @param       chr   : 要显示的字符 (' ' ~ '~')
 * @retval      无
 */
void bsp_lcd_show_char(uint16_t x, uint16_t y, uint8_t font, uint16_t color, uint8_t mode, uint8_t chr)
{
    const uint8_t *ch_code; /* 存放chr字符对应数组的首地址 */
    uint8_t ch_width; /* 字符的宽度 */
    uint8_t ch_height; /* 字符的高度 */
    uint8_t ch_size; /* 字符的大小(字节) */
    uint8_t ch_offset; /* 字符在字库的相对位置 */
    uint8_t byte_index; /* 字符对应数据的索引值 */
    uint8_t byte_code; /* 字符对应数据 */
    uint8_t bit_index; /* 字符对应字节数据的位索引 */
    uint16_t colortemp = 0; /* 颜色数据 */
    uint16_t pix_index = 0;
    uint16_t *pcolor = NULL;

    /* 字体大小(字节) =       字体宽度占用字体大小              * 字体高度 */
    ch_size = ((font / 2) / 8 + (((font / 2) % 8) ? 1 : 0)) * font; /* 得到字体一个字符对应点阵集所占的字节数 */

    pcolor = heap_caps_malloc(font * (font / 2) * 2, MALLOC_CAP_DMA); /* 申请大小 */
    uint16_t color_tmp = ((color & 0x00FF) << 8) | ((color & 0xFF00) >> 8); /* 需要转换一下颜色值 */

    if (NULL == pcolor)
    {
        ESP_LOGE(TAG, "Memory for bitmap is not enough");
        return;
    }

    ch_offset = chr - ' '; /* 得到偏移后的值（ASCII字库是从空格开始取模，所以-' '就是对应字符的字库） */

    switch (font)
    {
        case 12:
            ch_code = (uint8_t *)asc2_1206[ch_offset]; /* 调用1206字体 */
            ch_width = 6;
            ch_height = 12;
            break;

        case 16:
            ch_code = (uint8_t *)asc2_1608[ch_offset]; /* 调用1608字体 */
            ch_width = 8;
            ch_height = 16;
            break;

        case 24:
            ch_code = (uint8_t *)asc2_2412[ch_offset]; /* 调用2412字体 */
            ch_width = 12;
            ch_height = 24;
            break;

        case 32:
            ch_code = (uint8_t *)asc2_3216[ch_offset]; /* 调用3216字体 */
            ch_width = 16;
            ch_height = 32;
            break;

        default:
            return;
    }

    for (byte_index = 0; byte_index < ch_size; byte_index++)
    {
        byte_code = ch_code[byte_index]; /* 获取字符的点阵数据 */

        for (bit_index = 0; bit_index < 8; bit_index++) /* 一个字节8个点 */
        {
            if ((byte_code & 0x80) != 0) /* 有效点,需要显示 */
            {
                colortemp = color_tmp;
                pcolor[pix_index] = colortemp;
                pix_index++;
            }
            else if (mode == 0) /* 无效点,不显示 */
            {
                colortemp = 0xFFFF;
                pcolor[pix_index] = colortemp;
                pix_index++;
            }
            /* mode == 1 且无效点时，跳过不写入 */

            if ((font == 12) && (bit_index == 5)) /* 12号字体每字节只有6位有效 */
            {
                break;
            }

            if ((font == 24) && (byte_index % 2)) /* 24号字体比较特殊,奇数字节只有四位有效 */
            {
                if (bit_index == 3)
                {
                    break;
                }
            }

            byte_code <<= 1; /* 移位, 以便获取下一个位的状态 */
        }
    }

    esp_lcd_panel_draw_bitmap(g_lcd_handle, x, y, x + ch_width, y + ch_height, (uint16_t *)pcolor);

    g_lcd_refresh_ok_flag = 0;

    do
    {
        /* 等待内部缓存刷新完成 */
        vTaskDelay(1);
    } while (g_lcd_refresh_ok_flag != 1);

    heap_caps_free(pcolor);
}

/**
 * @brief       显示数字
 * @param       x     : 起始x坐标
 * @param       y     : 起始y坐标
 * @param       font  : 字体大小 可选: 12, 16, 24, 32
 * @param       color : 数字颜色
 * @param       len   : 显示位数
 * @param       num   : 数值 (0 ~ 2^32)
 * @retval      无
 */
void bsp_lcd_show_num(uint16_t x, uint16_t y, uint8_t font, uint16_t color, uint8_t len, uint32_t num)
{
    uint8_t t, temp;
    uint8_t enshow = 0;

    for (t = 0; t < len; t++) /* 按总显示位数循环 */
    {
        temp = (num / _lcd_pow(10, len - t - 1)) % 10; /* 获取对应位的数字 */

        if (enshow == 0 && t < (len - 1)) /* 没有使能显示,且还有位要显示 */
        {
            if (temp == 0)
            {
                bsp_lcd_show_char(x + (font / 2) * t, y, font, color, 0, ' '); /* 显示空格,占位 */
                continue; /* 继续下个一位 */
            }
            else
            {
                enshow = 1; /* 使能显示 */
            }
        }

        bsp_lcd_show_char(x + (font / 2) * t, y, font, color, 0, temp + '0'); /* 显示字符 */
    }
}

/**
 * @brief       扩展显示数字(高位为0也显示)
 * @param       x     : 起始x坐标
 * @param       y     : 起始y坐标
 * @param       font  : 字体大小 可选: 12, 16, 24, 32
 * @param       color : 数字颜色
 * @param       len   : 显示位数
 * @param       mode  : 显示模式 [7]:0=不填充,1=填充0 [0]:0=非叠加,1=叠加
 * @param       num   : 数值 (0 ~ 2^32)
 * @retval      无
 */
void bsp_lcd_show_xnum(uint16_t x, uint16_t y, uint8_t font, uint16_t color, uint8_t len, uint8_t mode, uint32_t num)
{
    uint8_t t, temp;
    uint8_t enshow = 0;

    for (t = 0; t < len; t++) /* 按总显示位数循环 */
    {
        temp = (num / _lcd_pow(10, len - t - 1)) % 10; /* 获取对应位的数字 */

        if (enshow == 0 && t < (len - 1)) /* 没有使能显示,且还有位要显示 */
        {
            if (temp == 0)
            {
                if (mode & 0X80) /* 高位需要填充0 */
                {
                    bsp_lcd_show_char(x + (font / 2) * t, y, font, color, mode & 0X01, '0'); /* 用0占位 */
                }
                else
                {
                    bsp_lcd_show_char(x + (font / 2) * t, y, font, color, mode & 0X01, ' '); /* 用空格占位 */
                }
                continue;
            }
            else
            {
                enshow = 1; /* 使能显示 */
            }
        }
        bsp_lcd_show_char(x + (font / 2) * t, y, font, color, mode & 0X01, temp + '0');
    }
}

/**
 * @brief       显示字符串
 * @param       x     : 起始x坐标
 * @param       y     : 起始y坐标
 * @param       font  : 字体大小 可选: 12, 16, 24, 32
 * @param       color : 字符串颜色
 * @param       p     : 字符串首地址
 * @retval      无
 */
void bsp_lcd_show_string(uint16_t x, uint16_t y, uint8_t font, uint16_t color, char *p)
{
    uint8_t x0 = x;
    uint16_t width = g_lcd_dev.width;
    uint16_t height = g_lcd_dev.height;

    while ((*p <= '~') && (*p >= ' ')) /* 判断是不是非法字符! */
    {
        if (x + font / 2 > width)
        {
            x = x0;
            y += font;
        }

        if (y + font > height) break; /* 退出 */

        bsp_lcd_show_char(x, y, font, color, 0, *p);

        x += font / 2;
        p++;
    }
}

/**
 * @brief       格式化输出字符串到LCD
 * @param       x     : 起始x坐标
 * @param       y     : 起始y坐标
 * @param       font  : 字体大小 可选: 12, 16, 24, 32
 * @param       color : 字符串颜色
 * @param       fmt   : 格式化字符串
 * @param       ...   : 可变参数列表
 * @retval      输出的字符串长度
 */
uint16_t bsp_lcd_printf(uint16_t x, uint16_t y, uint8_t font, uint16_t color, const char *fmt, ...)
{
    char *buffer = calloc(320, 1);
    assert(buffer != NULL);

    va_list arg;
    va_start(arg, fmt);
    uint16_t len = vsnprintf(buffer, 256, fmt, arg);
    va_end(arg);

    bsp_lcd_show_string(x, y, font, color, buffer);

    free(buffer);

    return len;
}

/**
 * @brief       LCD更新完成回调函数
 * @param       无
 * @retval      无
 */
__weak_symbol void bsp_lcd_update_cplt_callback(void)
{
}

/**
 * @brief       SPI总线初始化
 * @param       无
 * @retval      无
 */
static void _lcd_spi_init(void)
{
    spi_bus_config_t buscfg = {
        .sclk_io_num = BSP_LCD_SCLK_PIN,
        .mosi_io_num = BSP_LCD_MOSI_PIN,
        .miso_io_num = BSP_LCD_MISO_PIN,
        .quadhd_io_num = -1,
        .quadwp_io_num = -1,
        .max_transfer_sz = LCD_BUFFER_SIZE,
    };

    ESP_ERROR_CHECK(spi_bus_initialize(LCD_SPI_HOST, &buscfg, SPI_DMA_CH_AUTO));
}

/**
 * @brief       XL9555 GPIO扩展芯片引脚初始化
 * @param       无
 * @retval      无
 */
static void _lcd_exio_pin_init(void)
{
    bsp_exio_pin_config_t exio_lcd_conifg = {
        .mode = BSP_EXIO_PIN_MODE_OUTPUT,
        .pin = BSP_LCD_PWR_PIN,
    };
    bsp_exio_conifg_pin(&exio_lcd_conifg);
    exio_lcd_conifg.pin = BSP_LCD_RST_PIN;
    bsp_exio_conifg_pin(&exio_lcd_conifg);
}

/**
 * @brief       LCD刷新完成回调函数
 * @param       panel_io : LCD面板IO句柄
 * @param       edata    : 事件数据
 * @param       arg      : 用户参数
 * @retval      false
 */
static bool _lcd_flush_ready_cb(esp_lcd_panel_io_handle_t panel_io, esp_lcd_panel_io_event_data_t *edata, void *arg)
{
    g_lcd_refresh_ok_flag = 1;
    bsp_lcd_update_cplt_callback();
    return false;
}

/**
 * @brief       计算m的n次方
 * @param       m : 底数
 * @param       n : 指数
 * @retval      m的n次方结果
 */
static uint32_t _lcd_pow(uint8_t m, uint8_t n)
{
    uint32_t result = 1;

    while (n--) result *= m;

    return result;
}
