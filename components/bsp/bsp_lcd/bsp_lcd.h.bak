#ifndef BSP_LCD_H
#define BSP_LCD_H

#include "common.h"
#include "bsp_exio.h"

#include "driver/gpio.h"
#include "esp_lcd_panel_io.h"
#include "esp_lcd_panel_interface.h"
#include "esp_lcd_panel_vendor.h"
#include "esp_lcd_panel_ops.h"
#include "esp_lcd_panel_commands.h"
#include "esp_lcd_panel_st7789.h"

#define LCD_SPI_HOST SPI2_HOST

#define LCD_2_4_INCH

#if defined LCD_2_4_INCH
#    define LCD_WIDTH  320
#    define LCD_HEIGHT 240
#else
#    define LCD_WIDTH  240
#    define LCD_HEIGHT 240
#endif

#define LCD_BUFFER_SIZE  (LCD_WIDTH * LCD_HEIGHT * sizeof(uint16_t))

#define BSP_LCD_SCLK_PIN GPIO_NUM_12
#define BSP_LCD_MOSI_PIN GPIO_NUM_11
#define BSP_LCD_MISO_PIN GPIO_NUM_13
#define BSP_LCD_RST_PIN  BSP_EXIO_NUM10
#define BSP_LCD_PWR_PIN  BSP_EXIO_NUM11
#define BSP_LCD_DC_PIN   GPIO_NUM_40
#define BSP_LCD_CS_PIN   GPIO_NUM_21

#define BSP_LCD_PWR(x)   bsp_exio_write_pin(BSP_LCD_PWR_PIN, x)
#define BSP_LCD_RST(x)   bsp_exio_write_pin(BSP_LCD_RST_PIN, x)

/* 常用颜色值 */
#define WHITE  0xFFFF /* 白色 */
#define BLACK  0x0000 /* 黑色 */
#define RED    0xF800 /* 红色 */
#define GREEN  0x07E0 /* 绿色 */
#define BLUE   0x001F /* 蓝色 */
#define PINK   0XF81F /* 粉色 */
#define YELLOW 0XFFE0 /* 黄色 */
#define CYAN   0X07FF /* 蓝绿色 */

/* 非常用颜色 */
#define BROWN      0XBC40 /* 棕色 */
#define BRRED      0XFC07 /* 棕红色 */
#define GRAY       0X8430 /* 灰色 */
#define DARKBLUE   0X01CF /* 深蓝色 */
#define LIGHTBLUE  0X7D7C /* 浅蓝色 */
#define GRAYBLUE   0X5458 /* 灰蓝色 */
#define LIGHTGREEN 0X841F /* 浅绿色 */
#define LGRAY      0XC618 /* 浅灰色(PANNEL),窗体背景色 */
#define LGRAYBLUE  0XA651 /* 浅灰蓝色(中间层颜色) */
#define LBBLUE     0X2B12 /* 浅棕蓝色(选择条目的反色) */

void bsp_lcd_init(void);
void bsp_lcd_set_dir(uint8_t dir);
void bsp_lcd_clear(uint16_t color);
void bsp_lcd_fill(uint16_t sx, uint16_t sy, uint16_t ex, uint16_t ey, uint16_t color);
void bsp_lcd_draw_point(uint16_t x, uint16_t y, uint16_t color);
void bsp_lcd_draw_line(uint16_t x1, uint16_t y1, uint16_t x2, uint16_t y2, uint16_t color);
void bsp_lcd_draw_hline(uint16_t x, uint16_t y, uint16_t len, uint16_t color);
void bsp_lcd_draw_rectangle(uint16_t x0, uint16_t y0, uint16_t x1, uint16_t y1, uint16_t color);
void bsp_lcd_draw_circle(uint16_t x0, uint16_t y0, uint16_t r, uint16_t color);
void bsp_lcd_show_char(uint16_t x, uint16_t y, uint8_t font, uint16_t color, uint8_t mode, uint8_t chr);
void bsp_lcd_show_num(uint16_t x, uint16_t y, uint8_t font, uint16_t color, uint8_t len, uint32_t num);
void bsp_lcd_show_xnum(uint16_t x, uint16_t y, uint8_t font, uint16_t color, uint8_t len, uint8_t mode, uint32_t num);
void bsp_lcd_show_string(uint16_t x, uint16_t y, uint8_t font, uint16_t color, char *p);
uint16_t bsp_lcd_printf(uint16_t x, uint16_t y, uint8_t font, uint16_t color, const char *fmt, ...);

__weak_symbol void bsp_lcd_update_cplt_callback(void);

#endif // BSP_LCD_H
