<component>
    <view width="800" height="480" scrollable="false" clickable="false"
          style_bg_opa="0" style_border_width="0"
          style_pad_left="0" style_pad_top="0" style_pad_right="0" style_pad_bottom="0">
        <!-- 主页按钮 -->
        <lv_button name="nav_home_btn"
                   x="10" y="430" width="70" height="40">
            <style name="style_user_btn"/>
            <lv_label name="nav_home_icon" width="content" height="content">
                <style name="style_user_icon_label"/>
            </lv_label>
            <screen_load_event screen="main_page" trigger="clicked" anim_type="fade_on" duration="500"/>
        </lv_button>
        <!-- 返回按钮 -->
        <lv_button name="nav_back_btn"
                   x="720" y="430" width="70" height="40">
            <style name="style_user_btn"/>
            <lv_label name="nav_back_icon" width="content" height="content">
                <style name="style_user_icon_label"/>
            </lv_label>
            <event_cb callback="nav_back" trigger="clicked"/>
        </lv_button>
    </view>
</component>
